# ── Legion Vittor — Environment Variables ─────────────────────────────────────
APP_NAME="Legion Vittor Virtual Office"
APP_ENV=development
SECRET_KEY=change-me-in-production

# Supabase (free tier — supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── LLMs (you already have these) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key
CLAUDE_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ── Free services ──────────────────────────────────────────────────────────────
# Resend (resend.com — free 3K emails/month)
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Razorpay test mode (razorpay.com — free)
RAZORPAY_KEY_ID=rzp_test_your-key
RAZORPAY_KEY_SECRET=your-secret

# Meta Graph API (developers.facebook.com — free)
META_ACCESS_TOKEN=your-page-access-token
META_INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id

# YouTube Data API v3 (console.cloud.google.com — free)
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
